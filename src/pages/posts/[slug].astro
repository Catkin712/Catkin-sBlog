---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = (await getCollection("posts")).filter(
        (post) => !post.data.draft,
    );

    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const pubDate = post.data.pubDate.toISOString().slice(0, 10);
const coverUrl = post.data.image?.url ?? "/defaultCover.png";
const coverAlt = post.data.image?.alt ?? `${post.data.title} 的文章封面`;
---

<BaseLayout
    pageTitle={post.data.title}
    description={post.data.description}
    showPageTitle={false}
>
    <article class="article-page">
        <header class="article-header">
            <div class="article-heading">
                <h1>{post.data.title}</h1>
                <p class="article-description">{post.data.description}</p>
                <div class="article-meta">
                    <span>作者：{post.data.author}</span>
                    <time datetime={post.data.pubDate.toISOString()}>{pubDate}</time>
                </div>
            </div>
            <img
                class="article-cover"
                src={coverUrl}
                alt={coverAlt}
                loading="lazy"
            />
        </header>

        <div class="article-content">
            <Content />
        </div>

        {
            post.data.tags.length > 0 && (
                <footer class="article-tags" aria-label="文章标签">
                    <p>标签</p>
                    <div>
                        {post.data.tags.map((tag) => (
                            <a href={`/tags/${encodeURIComponent(tag)}/`}>
                                {tag}
                            </a>
                        ))}
                    </div>
                </footer>
            )
        }
    </article>
</BaseLayout>

<style>
    .article-page {
        border: 1px solid var(--line-color);
        border-radius: 8px;
        background: var(--panel-bg);
        padding: clamp(1.25rem, 3vw, 2rem);
    }

    .article-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 180px;
        gap: 1.25rem;
        align-items: start;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--line-color);
    }

    .article-heading {
        display: grid;
        gap: 0.65rem;
    }

    .article-header h1 {
        margin: 0;
        overflow-wrap: anywhere;
        font-size: clamp(1.75rem, 4vw, 2.45rem);
        line-height: 1.22;
        letter-spacing: 0;
    }

    .article-description {
        margin: 0;
        color: var(--muted-color);
        font-size: 1rem;
        line-height: 1.7;
    }

    .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        margin-top: 0.85rem;
        color: var(--muted-color);
        font-size: 0.9rem;
    }

    .article-cover {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        max-width: 180px;
        justify-self: end;
        border-radius: 8px;
        object-fit: cover;
        background: var(--page-bg);
    }

    .article-content {
        margin-top: 1.5rem;
        font-size: 1.03rem;
        line-height: 1.85;
    }

    .article-content :global(h2),
    .article-content :global(h3) {
        margin: 2rem 0 0.75rem;
        line-height: 1.35;
    }

    .article-content :global(p) {
        margin: 1rem 0;
    }

    .article-content :global(a) {
        color: var(--accent-color);
    }

    .article-content :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
    }

    .article-tags {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid var(--line-color);
    }

    .article-tags p {
        margin: 0 0 0.5rem;
        color: var(--muted-color);
        font-size: 0.82rem;
        font-weight: 700;
    }

    .article-tags div {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .article-tags a {
        border: 1px solid var(--line-color);
        border-radius: 999px;
        padding: 0.16rem 0.5rem;
        background: var(--page-bg);
        color: var(--muted-color);
        font-size: 0.78rem;
        text-decoration: none;
    }

    .article-tags a:hover,
    .article-tags a:focus {
        border-color: var(--accent-color);
        color: var(--accent-color);
    }

    @media screen and (max-width: 560px) {
        .article-page {
            padding: 1rem;
        }

        .article-header {
            grid-template-columns: 1fr;
        }

        .article-cover {
            max-width: none;
            justify-self: start;
            width: 100%;
        }
    }
</style>
