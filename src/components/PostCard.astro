---
const { post } = Astro.props;
const rawDate = post.data.pubDate;
const pubDate =
    rawDate instanceof Date
        ? rawDate.toISOString().slice(0, 10)
        : String(rawDate).slice(0, 10);
const postUrl = `/posts/${post.id}/`;
const coverUrl = post.data.image?.url ?? "/defaultCover.png";
const coverAlt = post.data.image?.alt ?? `${post.data.title} 的文章封面`;
const category = post.data.category?.trim() || "未分类";
---

<article class="post-card">
    <a class="post-card-link" href={postUrl}>
        <img
            class="post-card-cover"
            src={coverUrl}
            alt={coverAlt}
            loading="lazy"
        />
        <div class="post-card-body">
            <div class="post-card-meta">
                <span>{pubDate}</span>
                <span>{post.data.author}</span>
                <span>{category}</span>
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
        </div>
    </a>
    <div class="post-card-tags" aria-label="文章标签">
        {
            post.data.tags.map((tag: string) => (
                <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
            ))
        }
    </div>
</article>

<style>
    .post-card {
        overflow: hidden;
        border: 1px solid var(--line-color);
        border-radius: 8px;
        background: var(--panel-bg);
    }

    .post-card-link {
        display: block;
        color: inherit;
        text-decoration: none;
    }

    .post-card-cover {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        background: var(--page-bg);
    }

    .post-card-body {
        display: grid;
        gap: 0.45rem;
        padding: 1rem 1.1rem 0;
    }

    .post-card-link:hover h2,
    .post-card-link:focus h2 {
        color: var(--accent-color);
    }

    .post-card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 0.75rem;
        color: var(--muted-color);
        font-size: 0.85rem;
    }

    .post-card h2 {
        margin: 0;
        overflow-wrap: anywhere;
        font-size: 1.28rem;
        line-height: 1.35;
        letter-spacing: 0;
    }

    .post-card p {
        margin: 0;
        color: var(--muted-color);
        line-height: 1.55;
    }

    .post-card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.85rem;
        padding: 0 1.1rem 1.1rem;
    }

    .post-card-tags a {
        border: 1px solid var(--line-color);
        border-radius: 999px;
        padding: 0.2rem 0.55rem;
        background: var(--page-bg);
        color: var(--muted-color);
        font-size: 0.8rem;
        text-decoration: none;
    }

    .post-card-tags a:hover,
    .post-card-tags a:focus {
        border-color: var(--accent-color);
        color: var(--accent-color);
    }

    @media screen and (max-width: 560px) {
        .post-card h2 {
            font-size: 1.15rem;
        }
    }
</style>
